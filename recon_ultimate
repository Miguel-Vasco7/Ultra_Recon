###########################################################################################################################################################
###                                                     3. Mineração de Endpoints (Caminhos e JS)                                                       ###
###########################################################################################################################################################

### Coletando URLs (Wayback + Katana + UrlFinder)

### 1. Coleta histórica
echo "alvo.com" | waybackurls > urls_wayback.txt

### 2. Coleta ativa (Katana potente)
katana -u "https://alvo.com" -d 3 -jc -kf > urls_katana.txt

### 3. Coleta passiva ampla
urlfinder -u "alvo.com" -subs > urls_finder.txt

### 4. Busca urls antigas ainda em funcionamento  
echo "unitel.com" | gau | grep "=" > urls_gau.txt

### 5. Serve para buscar URLs de todos os subdomínios do alvo, não apenas do domínio principal.
echo "unitel.com" | gau --subs | grep "="  > urls_gau.txt

### 6. Busca urls antigas ainda em funcionamento e esconde os erros
echo "unitel.com" | gau 2>/dev/null | grep "="  > urls_gau.txt

### 7. Wayback (histórico)
cat ativos_urls.txt | waybackurls > urls_wayback.txt

### 7. Junta TUDO, remove duplicatas e salva a lista final
cat urls_wayback.txt urls_katana.txt urls_finder.txt urls_wayback.txt urls_katana.txt urls_finder.txt urls_gau.txt | sort -u > urls_all_final_endpoints.txt

### 8. Katana (crawling ativo, precisa de https://)
cat ativos_urls.txt | sed 's/^/https:\/\//' | katana -d 3 -jc -kf -silent > urls_katana.txt

### 9. URLFinder (coleta passiva ampla)
cat ativos_urls.txt | urlfinder -subs > urls_finder.txt

### 10. A Grande Limpeza (Tira lixo visual) 
grep -avE "\.png|\.jpg|\.jpeg|\.gif|\.svg|\.woff|\.ttf|\.css|\.ico" urls_all_final_endpoints.txt | sort -u > urls_limpas.txt

### 11. Para encontrar pontos de Injeção (SQLi, XSS, SSRF): Hackers buscam URLs que contenham parâmetros (?id=, &search=).
grep "?" urls_all_final_endpoints.txt | grep -vE "\.png|\.jpg|\.jpeg" > urls_parametros.txt

### 12. Para encontrar arquivos sensíveis (Informação Exposta):
grep -iE "\.db|\.sql|\.txt|\.log|\.xml|\.json|\.env|\.zip|\.bak|\.swp" urls_all_final_endpoints.txt > targets_sensiveis.txt

###  13. Filtrar com o httpx
cat urls_limpas.txt | httpx -silent -status-code -no-color > alvos_vivos.txt -> sem banner httpx sujo nos arquivos 
cat urls_limpas.txt | httpx -mc 200,403,401,500 -title -content-length -tech-detect > alvos_priorizados

### Foca onde importa: endpoints com parâmetros
grep -E "[?&=]" alvos_priorizados.txt > com_parametros.txt
