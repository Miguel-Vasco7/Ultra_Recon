### 2. Filtragem de Alvos Vivos

# Verifica quem responde HTTP/HTTPS e tira o "lixo"
cat subs.txt | httpx -silent -mc 200,403,500,401,301,302 -title -tech-detect -content-length > subs_ativos.txt

# Cria uma lista limpa (com os resultados do httpx)  só com as URLs (essencial para o Nuclei e Katana)
cat subs_ativos.txt | cut -d' ' -f1 > ativos_urls.txt
