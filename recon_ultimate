# Wayback (histórico)
cat ativos_urls.txt | waybackurls > urls_wayback.txt

# Katana (crawling ativo, precisa de https://)
cat ativos_urls.txt | sed 's/^/https:\/\//' | katana -d 3 -jc -kf -silent > urls_katana.txt

# URLFinder (coleta passiva ampla)
cat ativos_urls.txt | urlfinder -subs > urls_finder.txt

# Colocar tudo em um só arquivo 
cat urls_wayback.txt urls_katana.txt urls_finder.txt | sort -u > urls_amass.txt

# Filtrar
grep -avE "\.(png|jpg|jpeg|gif|svg|woff|ttf|css|ico)$" urls_amass.txt | sort -u > urls_filtradas.txt

# Usar o Httpx pra ver quais estão ativos
cat urls_filtradas.txt | httpx -silent -mc 200,403,401,500 -title -content-length -tech-detect -status-code > alvos_priorizados.txt

