#=============================================
# 3. Mineração de Endpoints (Caminhos e JS)| #
#=============================================

### Coletando URLs (Wayback + Katana + UrlFinder)

# 1. Coleta histórica
echo "alvo.com" | waybackurls > urls_wayback.txt

# 2. Coleta ativa (Katana potente)
katana -u "https://alvo.com" -d 3 -jc -kf > urls_katana.txt

# 3. Coleta passiva ampla
urlfinder -u "alvo.com" -subs > urls_finder.txt

# 4. Junta TUDO, remove duplicatas e salva a lista final
cat urls_wayback.txt urls_katana.txt urls_finder.txt | sort -u > urls_all_final.txt

# 5. A Grande Limpeza (Tira lixo visual) 
grep -avE "\.png|\.jpg|\.jpeg|\.gif|\.svg|\.woff|\.ttf|\.css|\.ico" urls_all_final.txt | sort -u > urls_limpas.txt

# Para encontrar pontos de Injeção (SQLi, XSS, SSRF): Hackers buscam URLs que contenham parâmetros (?id=, &search=).
grep "?" urls_limpas.txt | grep -vE "\.png|\.jpg|\.jpeg" > urls_parametros.txt

# Para encontrar arquivos sensíveis (Informação Exposta):
grep -iE "\.db|\.sql|\.txt|\.log|\.xml|\.json|\.env|\.zip|\.bak|\.swp" urls_all_final.txt > targets_sensiveis.txt

# 6. Filtrar com o httpx 
cat urls_limpas.txt | httpx -mc 200,403,401,500 -title -content-length -tech-detect > alvos_priorizados.txt

